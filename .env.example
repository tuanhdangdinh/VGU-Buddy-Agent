# ==========================================
# VGU RAG Agent - Environment Configuration
# ==========================================

# ─── Application Server ───
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true
APP_NAME="Study Buddy - VGU"
APP_VERSION="1.0.0"

# ─── Security ───
# The API key required to access the /ask endpoints
AGENT_API_KEY=dev-key-change-me
ALLOWED_ORIGINS=*

# ─── Rate Limiting & Budgets ───
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0

# ─── Redis (Stateless Storage) ───
# Used for Rate Limit, Cost Guard, and Chat History
# Example for local: redis://localhost:6379/0
# Example for docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── Generative AI (LLM) ───
# Obtain a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.0-flash

# ─── Streamlit Frontend (Optional) ───
API_URL=http://localhost:8000
# STREAMLIT_SERVER_HEADLESS=true
# STREAMLIT_SERVER_ENABLE_CORS=false


AGENT_API_KEY=my-secret-key-change-in-production
